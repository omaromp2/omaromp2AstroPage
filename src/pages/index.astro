---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getCollection } from "astro:content";
import { projects, openSourceContributions } from "../data/projects";

const posts = (await getCollection("blog")).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const last_posts = posts.slice(0, 3);
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5">
    <div class="text-xl py-1">Hey there 👋</div>
    <div class="text-5xl font-bold">I'm Omar Ponce</div>
    <div class="text-3xl py-3 font-bold">Dad of 2 👧, husband, and Software Engineer 👨‍💻</div>
    <div class="py-2">
      <p class="text-lg">
      Proud husband and father of two. I'm a software engineer from San Juan, Puerto Rico with 10+ years building web apps and integrations—mostly Laravel, .NET, and modern front-ends (Vue & React).
     </p>
    </div>
    <div class="mt-8">
      <a class="btn" href="https://www.linkedin.com/in/omar-ponce-41849a67/" target="_blank"> Let's connect!</a>
    </div>
  </div>

  <div>
    <div class="text-3xl w-full font-bold mb-2">Some of the latest projects I have worked {"</>"}</div>
  </div>

  {
    projects.map((project, i) => (
      <>
        <HorizontalCard
          title={project.title}
          img={project.img}
          desc={project.desc}
          url={project.url}
          badge={project.badge}
          imgClass={project.imgClass}
          target={project.target}
        />
        {i < projects.length - 1 && <div class="divider my-0" />}
      </>
    ))
  }

  <div>
    <div class="text-3xl w-full font-bold mb-2 mt-10">Open Source Contributions</div>
  </div>

  {
    openSourceContributions.map((contribution, i) => (
      <>
        <HorizontalCard
          title={contribution.title}
          img={contribution.img}
          desc={contribution.desc}
          url={contribution.url}
          badge={contribution.badge}
          imgClass={contribution.imgClass}
        />
        {i < openSourceContributions.length - 1 && <div class="divider my-0" />}
      </>
    ))
  }

  <div>
    <div class="text-3xl w-full font-bold mb-5 mt-10">Latest from blog</div>
  </div>

  {
    last_posts.map((post) => (
      <>
        <HorizontalCard
          title={post.data.title}
          img={post.data.heroImage}
          desc={post.data.description}
          url={"/omaromp2AstroPage/blog/" + post.id}
          target="_self"
          badge={post.data.badge}
        />
        <div class="divider my-0" />
      </>
    ))
  }
</BaseLayout>
