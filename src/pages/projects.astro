---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { projects, openSourceContributions } from "../data/projects";
---

<BaseLayout title="Projects" sideBarActiveItemID="projects">
  <div>
    <div class="text-3xl w-full font-bold mb-5">Projects</div>
  </div>

  {
    projects.map((project, i) => (
      <>
        <HorizontalCard
          title={project.title}
          img={project.img}
          desc={project.desc}
          url={project.url}
          badge={project.badge}
          imgClass={project.imgClass}
          target={project.target}
        />
        {i < projects.length - 1 && <div class="divider my-0" />}
      </>
    ))
  }

  <div>
    <div class="text-3xl w-full font-bold mb-5 mt-10">Open Source Contributions</div>
  </div>

  {
    openSourceContributions.map((contribution, i) => (
      <>
        <HorizontalCard
          title={contribution.title}
          img={contribution.img}
          desc={contribution.desc}
          url={contribution.url}
          badge={contribution.badge}
          imgClass={contribution.imgClass}
        />
        {i < openSourceContributions.length - 1 && <div class="divider my-0" />}
      </>
    ))
  }
</BaseLayout>
